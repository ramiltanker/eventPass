generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  firstName         String
  lastName          String
  middleName        String?
  passwordHash      String
  role              UserRole        @default(TEACHER)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  consultations     Consultation[]
  resetToken        String?
  resetTokenExpires DateTime?
  teacherInvites    TeacherInvite[]
}

model TeacherInvite {
  id             String    @id @default(cuid())
  email          String    @unique
  tokenHash      String    @unique
  tokenEncrypted String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?

  @@index([expiresAt])
}

model Consultation {
  id                  Int      @id @default(autoincrement())
  subject             String
  startsAt            DateTime
  endsAt              DateTime
  withoutIntervals    Boolean  @default(false)
  slotDurationMinutes Int?
  meetingLink         String
  description         String?

  teacherId String
  teacher   User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  slots    Slot[]
  bookings Booking[]

  createdAt DateTime @default(now())
}

model Slot {
  id       Int      @id @default(autoincrement())
  startsAt DateTime
  endsAt   DateTime

  consultationId Int
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  booking Booking?

  createdAt DateTime @default(now())

  @@unique([consultationId, startsAt])
}

model Booking {
  id Int @id @default(autoincrement())

  firstName  String
  lastName   String
  middleName String?
  email      String
  group      String

  consultationId Int?
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  slotId Int?  @unique
  slot   Slot? @relation(fields: [slotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([consultationId])
}